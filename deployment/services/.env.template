# EURION Backend Services - Environment Configuration

# Domain
PUBLIC_DOMAIN=eurion.example.com

# JWT Configuration (must match across all services)
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_32_characters_long

# Database Passwords (from infrastructure/.env)
PG_IDENTITY_PASSWORD=
PG_ORG_PASSWORD=
PG_AUDIT_PASSWORD=
PG_MESSAGING_PASSWORD=
PG_FILE_PASSWORD=
PG_VIDEO_PASSWORD=
PG_NOTIFICATION_PASSWORD=
PG_ADMIN_PASSWORD=

# Redis Password (from infrastructure/.env)
REDIS_PASSWORD=

# MinIO Credentials (from storage/.env)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Meilisearch (from storage/.env)
MEILISEARCH_MASTER_KEY=

# TURN Server (from coturn/.env)
TURN_USERNAME=
TURN_PASSWORD=

# Optional: Ollama for AI service
OLLAMA_URL=http://ollama:11434
