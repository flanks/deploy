# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  EURION Infrastructure — PostgreSQL, Redis, Kafka                        ║
# ║  Generated by Eurion Customer Deployment for {{ org_name }}              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

networks:
  eurion-net:
    external: true

services:
  # ── PostgreSQL 16 ──────────────────────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: eurion-postgres
    restart: unless-stopped
    networks:
      - eurion-net
    ports:
      - "127.0.0.1:5432:5432"
    environment:
      POSTGRES_USER: eurion
      POSTGRES_PASSWORD: "{{ postgres_password }}"
      POSTGRES_DB: postgres
    volumes:
      - {{ eurion_data }}/postgres:/var/lib/postgresql/data
      - {{ eurion_root }}/config/init-databases.sql:/docker-entrypoint-initdb.d/init-databases.sql:ro
    command: >
      postgres
        -c shared_buffers={{ pg_shared_buffers }}
        -c max_connections={{ pg_max_connections }}
        -c effective_cache_size={{ pg_shared_buffers }}
        -c work_mem=16MB
        -c maintenance_work_mem=128MB
        -c wal_level=replica
        -c max_wal_size=1GB
        -c checkpoint_completion_target=0.9
        -c log_min_duration_statement=1000
        -c log_statement=ddl
        -c log_connections=on
        -c log_disconnections=on
        -c log_lock_waits=on
        -c timezone=UTC
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U eurion"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  # ── Redis 7 ────────────────────────────────────────────────────────────────
  redis:
    image: redis:7-alpine
    container_name: eurion-redis
    restart: unless-stopped
    networks:
      - eurion-net
    ports:
      - "127.0.0.1:6379:6379"
    command: >
      redis-server
        --requirepass "{{ redis_password }}"
        --maxmemory {{ redis_maxmemory }}
        --maxmemory-policy allkeys-lru
        --appendonly yes
        --appendfsync everysec
        --tcp-backlog 511
        --timeout 300
        --tcp-keepalive 300
    volumes:
      - {{ eurion_data }}/redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "{{ redis_password }}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ── Kafka (KRaft mode — no Zookeeper) ──────────────────────────────────────
  kafka:
    image: bitnami/kafka:3.7
    container_name: eurion-kafka
    restart: unless-stopped
    networks:
      - eurion-net
    ports:
      - "127.0.0.1:9092:9092"
    environment:
      KAFKA_CFG_NODE_ID: "0"
      KAFKA_CFG_PROCESS_ROLES: controller,broker
      KAFKA_CFG_CONTROLLER_QUORUM_VOTERS: "0@kafka:9093"
      KAFKA_CFG_LISTENERS: PLAINTEXT://:9092,CONTROLLER://:9093
      KAFKA_CFG_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092
      KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
      KAFKA_CFG_CONTROLLER_LISTENER_NAMES: CONTROLLER
      KAFKA_CFG_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_CFG_AUTO_CREATE_TOPICS_ENABLE: "true"
      KAFKA_CFG_NUM_PARTITIONS: "3"
      KAFKA_CFG_DEFAULT_REPLICATION_FACTOR: "1"
      KAFKA_CFG_LOG_RETENTION_HOURS: "168"
      KAFKA_CFG_LOG_RETENTION_BYTES: "1073741824"
      KAFKA_HEAP_OPTS: "-Xmx{{ kafka_heap_size }} -Xms{{ kafka_heap_size }}"
    volumes:
      - {{ eurion_data }}/kafka:/bitnami/kafka
    healthcheck:
      test: ["CMD-SHELL", "kafka-topics.sh --bootstrap-server localhost:9092 --list || exit 1"]
      interval: 15s
      timeout: 10s
      retries: 10
      start_period: 60s
