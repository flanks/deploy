# Eurion Prometheus Configuration
# Generated by Eurion Customer Deployment for {{ org_name }}

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  scrape_timeout: 10s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']

  - job_name: 'cadvisor'
    static_configs:
      - targets: ['cadvisor:8080']

  - job_name: 'traefik'
    static_configs:
      - targets: ['traefik:8080']

  - job_name: 'eurion-services'
    scrape_interval: 30s
    static_configs:
      - targets:
{% for svc in services %}
{% if svc.required | string | lower in ['true', 'yes'] %}
          - '{{ svc.name }}:{{ svc.port }}'
{% endif %}
{% endfor %}
    metrics_path: /health
