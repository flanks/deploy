# ║  Generated by Eurion Customer Deployment for {{ org_name }}              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

services:
  coturn:
    image: coturn/coturn:4.6.2-alpine
    container_name: eurion-coturn
    restart: unless-stopped
    network_mode: host
    volumes:
      - {{ eurion_root }}/config/turnserver.conf:/etc/turnserver.conf:ro
    command: ["-c", "/etc/turnserver.conf"]
    healthcheck:
      test: ["CMD-SHELL", "nc -z 127.0.0.1 3478 || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 3
