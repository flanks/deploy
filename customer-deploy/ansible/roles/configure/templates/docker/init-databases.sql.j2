-- ╔════════════════════════════════════════════════════════════════════════════╗
-- ║  EURION — Database Initialization                                        ║
-- ║  Creates one database per microservice (strict boundary enforcement)      ║
-- ║  Generated by Eurion Customer Deployment for {{ org_name }}              ║
-- ╚════════════════════════════════════════════════════════════════════════════╝

-- Core services (always required)
CREATE DATABASE eurion_identity;
CREATE DATABASE eurion_org;
CREATE DATABASE eurion_audit;
CREATE DATABASE eurion_messaging;
CREATE DATABASE eurion_file;
CREATE DATABASE eurion_notification;
CREATE DATABASE eurion_admin;
CREATE DATABASE eurion_workflow;
CREATE DATABASE eurion_preview;

-- Optional services (created regardless; no harm if unused)
{% if feature_video | default(true) | bool %}
CREATE DATABASE eurion_video;
{% endif %}
{% if feature_search | default(true) | bool %}
CREATE DATABASE eurion_search;
{% endif %}
{% if feature_ai | default(true) | bool %}
CREATE DATABASE eurion_ai;
{% endif %}
{% if feature_transcription | default(false) | bool %}
CREATE DATABASE eurion_transcription;
{% endif %}
{% if feature_bridge | default(false) | bool %}
CREATE DATABASE eurion_bridge;
{% endif %}

-- Grant privileges
{% for svc in services %}
{% if svc.db != 'postgres' %}
GRANT ALL PRIVILEGES ON DATABASE {{ svc.db }} TO eurion;
{% endif %}
{% endfor %}
