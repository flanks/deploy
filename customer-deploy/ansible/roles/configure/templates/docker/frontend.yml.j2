# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  EURION Frontend — React Web App (Nginx)                                 ║
# ║  Generated by Eurion Customer Deployment for {{ org_name }}              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

networks:
  eurion-net:
    external: true

services:
  frontend:
    image: eurion-frontend:{{ eurion_version }}
    container_name: eurion-frontend
    restart: unless-stopped
    networks:
      - eurion-net
    ports:
      - "127.0.0.1:8080:80"
    labels:
      - "traefik.enable=true"
      # Main app
      - "traefik.http.routers.app.rule=Host(`{{ app_domain }}`)"
      - "traefik.http.routers.app.entrypoints=websecure"
      - "traefik.http.routers.app.tls=true"
{% if tls_method == 'letsencrypt' %}
      - "traefik.http.routers.app.tls.certresolver=letsencrypt"
{% endif %}
      - "traefik.http.routers.app.middlewares=secure-headers@file"
      - "traefik.http.services.app.loadbalancer.server.port=80"
      # Meet subdomain → same frontend, SPA handles /meet routes
      - "traefik.http.routers.meet.rule=Host(`{{ meet_domain }}`)"
      - "traefik.http.routers.meet.entrypoints=websecure"
      - "traefik.http.routers.meet.tls=true"
{% if tls_method == 'letsencrypt' %}
      - "traefik.http.routers.meet.tls.certresolver=letsencrypt"
{% endif %}
      - "traefik.http.routers.meet.middlewares=secure-headers@file"
      - "traefik.http.services.meet.loadbalancer.server.port=80"
      # Admin portal → same frontend, route handles admin UI
      - "traefik.http.routers.admin-portal.rule=Host(`{{ admin_domain }}`)"
      - "traefik.http.routers.admin-portal.entrypoints=websecure"
      - "traefik.http.routers.admin-portal.tls=true"
{% if tls_method == 'letsencrypt' %}
      - "traefik.http.routers.admin-portal.tls.certresolver=letsencrypt"
{% endif %}
      - "traefik.http.routers.admin-portal.middlewares=secure-headers@file"
      - "traefik.http.services.admin-portal.loadbalancer.server.port=80"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:80/"]
      interval: 15s
      timeout: 5s
      retries: 3
