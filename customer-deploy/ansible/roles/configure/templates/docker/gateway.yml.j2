# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  EURION Gateway — Traefik Reverse Proxy                                  ║
# ║  Generated by Eurion Customer Deployment for {{ org_name }}              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

networks:
  eurion-net:
    external: true

services:
  traefik:
    image: traefik:v2.11
    container_name: eurion-traefik
    restart: unless-stopped
    networks:
      - eurion-net
    ports:
      - "80:80"
      - "443:443"
    command:
      - "--api.dashboard=true"
      - "--api.insecure=false"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--providers.docker.network=eurion-net"
      - "--providers.file.filename=/etc/traefik/dynamic.yml"
      - "--providers.file.watch=true"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.web.http.redirections.entryPoint.to=websecure"
      - "--entrypoints.web.http.redirections.entryPoint.scheme=https"
      - "--entrypoints.websecure.address=:443"
{% if tls_method == 'letsencrypt' %}
      - "--certificatesresolvers.letsencrypt.acme.email={{ acme_email }}"
      - "--certificatesresolvers.letsencrypt.acme.storage=/letsencrypt/acme.json"
      - "--certificatesresolvers.letsencrypt.acme.httpchallenge=true"
      - "--certificatesresolvers.letsencrypt.acme.httpchallenge.entrypoint=web"
{% endif %}
      - "--log.level=WARN"
      - "--accesslog=true"
      - "--accesslog.format=json"
      - "--metrics.prometheus=true"
      - "--metrics.prometheus.addEntryPointsLabels=true"
      - "--metrics.prometheus.addServicesLabels=true"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ eurion_root }}/config/traefik-dynamic.yml:/etc/traefik/dynamic.yml:ro
{% if tls_method == 'letsencrypt' %}
      - {{ eurion_data }}/letsencrypt:/letsencrypt
{% endif %}
{% if tls_method in ['selfsigned', 'custom'] %}
      - {{ eurion_root }}/tls:/tls:ro
{% endif %}
    labels:
      - "traefik.enable=true"
      # Dashboard (optional, admin-only)
      - "traefik.http.routers.dashboard.rule=Host(`traefik.{{ domain }}`) && (PathPrefix(`/api`) || PathPrefix(`/dashboard`))"
      - "traefik.http.routers.dashboard.entrypoints=websecure"
      - "traefik.http.routers.dashboard.tls=true"
{% if tls_method == 'letsencrypt' %}
      - "traefik.http.routers.dashboard.tls.certresolver=letsencrypt"
{% endif %}
      - "traefik.http.routers.dashboard.service=api@internal"
      - "traefik.http.routers.dashboard.middlewares=dashboard-auth"
      - "traefik.http.middlewares.dashboard-auth.basicauth.users=admin:{{ traefik_dashboard_htpasswd | default('$2y$10$placeholder') }}"
    healthcheck:
      test: ["CMD", "wget", "--spider", "--quiet", "http://localhost:80/ping"]
      interval: 15s
      timeout: 5s
      retries: 3
