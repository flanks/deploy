# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  EURION Storage — MinIO (S3) + Meilisearch                              ║
# ║  Generated by Eurion Customer Deployment for {{ org_name }}              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

networks:
  eurion-net:
    external: true

services:
  # ── MinIO (S3-compatible Object Storage) ───────────────────────────────────
  minio:
    image: minio/minio:latest
    container_name: eurion-minio
    restart: unless-stopped
    networks:
      - eurion-net
    ports:
      - "127.0.0.1:9000:9000"
      - "127.0.0.1:9001:9001"
    environment:
      MINIO_ROOT_USER: "{{ minio_root_user }}"
      MINIO_ROOT_PASSWORD: "{{ minio_root_password }}"
      MINIO_BROWSER_REDIRECT_URL: "https://s3console.{{ domain }}"
    command: server /data --console-address ":9001"
    volumes:
      - {{ eurion_data }}/minio:/data
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 15s

  # ── MinIO Bucket Initialization ────────────────────────────────────────────
  minio-init:
    image: minio/mc:latest
    container_name: eurion-minio-init
    networks:
      - eurion-net
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set eurion http://minio:9000 {{ minio_root_user }} {{ minio_root_password }};
      mc mb --ignore-existing eurion/eurion-files;
      mc mb --ignore-existing eurion/eurion-avatars;
      mc mb --ignore-existing eurion/eurion-recordings;
      mc mb --ignore-existing eurion/eurion-backups;
      mc anonymous set download eurion/eurion-avatars;
      echo 'Buckets initialized successfully';
      exit 0;
      "

{% if feature_search | default(true) | bool %}
  # ── Meilisearch (Full-Text Search) ─────────────────────────────────────────
  meilisearch:
    image: getmeili/meilisearch:v1.7
    container_name: eurion-meilisearch
    restart: unless-stopped
    networks:
      - eurion-net
    ports:
      - "127.0.0.1:7700:7700"
    environment:
      MEILI_ENV: production
      MEILI_MASTER_KEY: "{{ meili_master_key }}"
      MEILI_NO_ANALYTICS: "true"
      MEILI_LOG_LEVEL: WARN
    volumes:
      - {{ eurion_data }}/meilisearch:/meili_data
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--spider", "http://localhost:7700/health"]
      interval: 15s
      timeout: 5s
      retries: 5
{% endif %}
