# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  EURION Services — All 15 Microservices                                  ║
# ║  Generated by Eurion Customer Deployment for {{ org_name }}              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

networks:
  eurion-net:
    external: true

x-common-env: &common-env
  NODE_ENV: production
  LOG_LEVEL: info
  REDIS_URL: "redis://:{{ redis_password }}@redis:6379"
  KAFKA_BROKERS: "kafka:9092"
  JWT_SECRET: "{{ jwt_secret }}"
  JWT_ISSUER: "EURION"
  CORS_ORIGINS: "{{ cors_origins }}"
  RATE_LIMIT_MAX: "100"
  RATE_LIMIT_WINDOW_MS: "60000"

x-common: &common
  restart: unless-stopped
  networks:
    - eurion-net
  logging:
    driver: json-file
    options:
      max-size: "50m"
      max-file: "5"

services:
  # ── API Gateway (:3000) ────────────────────────────────────────────────────
  gateway:
    <<: *common
    image: eurion-gateway:{{ eurion_version }}
    container_name: eurion-gateway
    ports:
      - "127.0.0.1:3000:3000"
    environment:
      <<: *common-env
      SERVICE_NAME: gateway
      SERVICE_PORT: "3000"
      DATABASE_URL: "postgresql://eurion:{{ postgres_password }}@postgres:5432/postgres"
      KAFKA_CLIENT_ID: gateway
      IDENTITY_SERVICE_URL: "http://identity-service:3001"
      ORG_SERVICE_URL: "http://org-service:3002"
      AUDIT_SERVICE_URL: "http://audit-service:3003"
      MESSAGING_SERVICE_URL: "http://messaging-service:3004"
      FILE_SERVICE_URL: "http://file-service:3005"
      VIDEO_SERVICE_URL: "http://video-service:3006"
      NOTIFICATION_SERVICE_URL: "http://notification-service:3007"
      ADMIN_SERVICE_URL: "http://admin-service:3008"
      SEARCH_SERVICE_URL: "http://search-service:3009"
      AI_SERVICE_URL: "http://ai-service:3010"
      WORKFLOW_SERVICE_URL: "http://workflow-service:3011"
      PREVIEW_SERVICE_URL: "http://preview-service:3012"
      TRANSCRIPTION_SERVICE_URL: "http://transcription-service:3013"
      BRIDGE_SERVICE_URL: "http://bridge-service:3014"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.api.rule=Host(`{{ api_domain }}`)"
      - "traefik.http.routers.api.entrypoints=websecure"
      - "traefik.http.routers.api.tls=true"
{% if tls_method == 'letsencrypt' %}
      - "traefik.http.routers.api.tls.certresolver=letsencrypt"
{% endif %}
      - "traefik.http.routers.api.middlewares=secure-headers@file,rate-limit@file"
      - "traefik.http.services.api.loadbalancer.server.port=3000"
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://localhost:3000/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

{% for svc in services %}
{% if svc.name != 'gateway' and svc.required | string | lower in ['true', 'yes'] %}
  # ── {{ svc.name }} (:{{ svc.port }}) ──────────────────────────────────────
  {{ svc.name }}:
    <<: *common
    image: eurion-{{ svc.name }}:{{ eurion_version }}
    container_name: eurion-{{ svc.name }}
    ports:
      - "127.0.0.1:{{ svc.port }}:{{ svc.port }}"
    environment:
      <<: *common-env
      SERVICE_NAME: {{ svc.name }}
      SERVICE_PORT: "{{ svc.port }}"
      DATABASE_URL: "postgresql://eurion:{{ postgres_password }}@postgres:5432/{{ svc.db }}"
      KAFKA_CLIENT_ID: {{ svc.name }}
{% if svc.name == 'file-service' %}
      S3_ENDPOINT: "http://minio:9000"
      S3_ACCESS_KEY: "{{ minio_root_user }}"
      S3_SECRET_KEY: "{{ minio_root_password }}"
      S3_BUCKET: "eurion-files"
      S3_REGION: "eu-west-1"
{% endif %}
{% if svc.name == 'video-service' %}
      TURN_SERVER_URL: "turn:turn.{{ domain }}:3478"
      TURN_USERNAME: "eurion"
      TURN_PASSWORD: "{{ turn_password }}"
      STUN_SERVER_URL: "stun:turn.{{ domain }}:3478"
      ANNOUNCED_IP: "{{ public_ip }}"
      MEDIASOUP_MIN_PORT: "40000"
      MEDIASOUP_MAX_PORT: "49999"
{% endif %}
{% if svc.name == 'search-service' %}
      MEILISEARCH_URL: "http://meilisearch:7700"
      MEILISEARCH_API_KEY: "{{ meili_master_key }}"
{% endif %}
{% if svc.name == 'ai-service' %}
      OLLAMA_HOST: "http://host.docker.internal:11434"
{% endif %}
{% if svc.name == 'preview-service' %}
      S3_ENDPOINT: "http://minio:9000"
      S3_ACCESS_KEY: "{{ minio_root_user }}"
      S3_SECRET_KEY: "{{ minio_root_password }}"
      S3_BUCKET: "eurion-files"
      GOTENBERG_URL: "http://gotenberg:3100"
      FILE_SERVICE_URL: "http://file-service:3005"
      INTERNAL_SECRET: "{{ internal_secret }}"
{% endif %}
{% if svc.name == 'transcription-service' %}
      WHISPER_ENDPOINT: "http://host.docker.internal:9300"
      AI_SERVICE_URL: "http://ai-service:3010"
{% endif %}
{% if svc.name == 'bridge-service' %}
      BRIDGE_TOKEN_ENC_KEY: "{{ bridge_token_enc_key }}"
      BRIDGE_INTERNAL_SECRET: "{{ bridge_internal_secret }}"
      SMTP_HOST: "{{ smtp_host | default('') }}"
      SMTP_PORT: "{{ smtp_port | default('587') }}"
      SMTP_USER: "{{ smtp_user | default('') }}"
      SMTP_PASS: "{{ smtp_pass | default('') }}"
      SMTP_FROM: "{{ smtp_from | default('') }}"
      WEB_APP_URL: "https://{{ app_domain }}"
      WEBHOOK_BASE_URL: "https://{{ api_domain }}/v1/bridge/webhook"
      GATEWAY_URL: "http://gateway:3000"
      INTERNAL_DOMAINS: "{{ domain }}"
{% endif %}
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://localhost:{{ svc.port }}/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

{% endif %}
{% endfor %}
  # ── Gotenberg (document conversion) ────────────────────────────────────────
  gotenberg:
    <<: *common
    image: gotenberg/gotenberg:8
    container_name: eurion-gotenberg
    ports:
      - "127.0.0.1:3100:3000"
    command:
      - "gotenberg"
      - "--api-timeout=120s"
      - "--api-root-path=/"
      - "--chromium-disable-javascript=true"
      - "--chromium-allow-list=file:///tmp/.*"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/health"]
      interval: 15s
      timeout: 5s
      retries: 3
