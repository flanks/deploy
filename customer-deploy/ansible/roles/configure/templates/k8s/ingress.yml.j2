# Eurion Kubernetes Ingress
# Generated by Eurion Customer Deployment for {{ org_name }}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: eurion-ingress
  namespace: {{ k8s_namespace_prefix }}-gateway
  labels:
    app.kubernetes.io/part-of: eurion
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: "100m"
    nginx.ingress.kubernetes.io/proxy-read-timeout: "300"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "300"
    nginx.ingress.kubernetes.io/proxy-connect-timeout: "60"
    nginx.ingress.kubernetes.io/websocket-services: "eurion-gateway"
    nginx.ingress.kubernetes.io/enable-cors: "true"
    nginx.ingress.kubernetes.io/cors-allow-origin: "{{ cors_origins }}"
    nginx.ingress.kubernetes.io/cors-allow-methods: "GET, POST, PUT, DELETE, PATCH, OPTIONS"
    nginx.ingress.kubernetes.io/cors-allow-headers: "DNT,X-CustomHeader,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Authorization,X-Request-ID"
{% if has_cert_manager | default(true) | bool %}
    cert-manager.io/cluster-issuer: letsencrypt-prod
{% endif %}
spec:
{% if has_cert_manager | default(true) | bool %}
  tls:
    - hosts:
        - {{ api_domain }}
        - {{ app_domain }}
        - {{ meet_domain }}
        - {{ admin_domain }}
      secretName: eurion-tls
{% endif %}
  ingressClassName: nginx
  rules:
    # API Gateway
    - host: {{ api_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: eurion-gateway
                port:
                  number: 3000

    # Web App Frontend
    - host: {{ app_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: eurion-frontend
                port:
                  number: 80

    # Meet subdomain
    - host: {{ meet_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: eurion-frontend
                port:
                  number: 80

    # Admin portal
    - host: {{ admin_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: eurion-frontend
                port:
                  number: 80
          - path: /grafana
            pathType: Prefix
            backend:
              service:
                name: eurion-grafana
                port:
                  number: 3000
