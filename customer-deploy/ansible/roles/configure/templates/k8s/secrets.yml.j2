# Eurion Kubernetes Secrets
# Generated by Eurion Customer Deployment for {{ org_name }}
---
{% for svc in services %}
{% if svc.required | string | lower in ['true', 'yes'] %}
apiVersion: v1
kind: Secret
metadata:
  name: eurion-{{ svc.name }}-secrets
  namespace: {{ k8s_namespace_prefix }}-{{ svc.name | regex_replace('-service$', '') }}
  labels:
    app.kubernetes.io/name: {{ svc.name }}
    app.kubernetes.io/part-of: eurion
type: Opaque
stringData:
  DATABASE_URL: "postgresql://eurion:{{ postgres_password }}@{{ pg_external_host | default('eurion-postgres-rw.' + k8s_namespace_prefix + '-infra.svc.cluster.local') }}:{{ pg_external_port | default('5432') }}/{{ svc.db }}"
  REDIS_URL: "redis://:{{ redis_password }}@{{ redis_external_host | default('eurion-redis-master.' + k8s_namespace_prefix + '-infra.svc.cluster.local') }}:{{ redis_external_port | default('6379') }}"
  JWT_SECRET: "{{ jwt_secret }}"
  KAFKA_BROKERS: "eurion-kafka-bootstrap.{{ k8s_namespace_prefix }}-infra.svc.cluster.local:9092"
{% if svc.name in ['file-service', 'preview-service'] %}
  S3_ACCESS_KEY: "{{ minio_root_user }}"
  S3_SECRET_KEY: "{{ minio_root_password }}"
{% endif %}
{% if svc.name == 'search-service' %}
  MEILISEARCH_API_KEY: "{{ meili_master_key }}"
{% endif %}
{% if svc.name == 'video-service' %}
  TURN_PASSWORD: "{{ turn_password }}"
{% endif %}
{% if svc.name == 'preview-service' %}
  INTERNAL_SECRET: "{{ internal_secret }}"
{% endif %}
{% if svc.name == 'bridge-service' %}
  BRIDGE_TOKEN_ENC_KEY: "{{ bridge_token_enc_key }}"
  BRIDGE_INTERNAL_SECRET: "{{ bridge_internal_secret }}"
  SMTP_PASS: "{{ smtp_pass | default('') }}"
{% endif %}
---
{% endif %}
{% endfor %}
