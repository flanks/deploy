# Eurion Kubernetes Service Deployment Template
# Generated by Eurion Customer Deployment for {{ org_name }}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: eurion-{{ item.name }}
  namespace: {{ k8s_namespace_prefix }}-{{ item.name | regex_replace('-service$', '') }}
  labels:
    app.kubernetes.io/name: {{ item.name }}
    app.kubernetes.io/part-of: eurion
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: eurion-{{ item.name }}
  namespace: {{ k8s_namespace_prefix }}-{{ item.name | regex_replace('-service$', '') }}
  labels:
    app.kubernetes.io/name: {{ item.name }}
    app.kubernetes.io/part-of: eurion
    app.kubernetes.io/version: "{{ eurion_version }}"
spec:
  replicas: {{ 3 if item.name == 'gateway' else 2 }}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ item.name }}
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 1
      maxSurge: 1
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ item.name }}
        app.kubernetes.io/part-of: eurion
    spec:
      serviceAccountName: eurion-{{ item.name }}
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        runAsGroup: 1000
        fsGroup: 1000
      containers:
        - name: {{ item.name }}
          image: eurion-{{ item.name }}:{{ eurion_version }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ item.port }}
              protocol: TCP
              name: http
          env:
            - name: NODE_ENV
              value: "production"
            - name: SERVICE_NAME
              value: "{{ item.name }}"
            - name: SERVICE_PORT
              value: "{{ item.port }}"
            - name: JWT_ISSUER
              value: "EURION"
            - name: CORS_ORIGINS
              value: "{{ cors_origins }}"
            - name: LOG_LEVEL
              value: "info"
            - name: RATE_LIMIT_MAX
              value: "100"
            - name: RATE_LIMIT_WINDOW_MS
              value: "60000"
            - name: KAFKA_CLIENT_ID
              value: "{{ item.name }}"
          envFrom:
            - secretRef:
                name: eurion-{{ item.name }}-secrets
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "{{ '2000m' if item.name in ['gateway', 'video-service'] else '500m' }}"
              memory: "{{ '1Gi' if item.name in ['gateway', 'video-service', 'ai-service'] else '512Mi' }}"
          livenessProbe:
            httpGet:
              path: /health
              port: {{ item.port }}
            initialDelaySeconds: 30
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /health
              port: {{ item.port }}
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          startupProbe:
            httpGet:
              path: /health
              port: {{ item.port }}
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 30
---
apiVersion: v1
kind: Service
metadata:
  name: eurion-{{ item.name }}
  namespace: {{ k8s_namespace_prefix }}-{{ item.name | regex_replace('-service$', '') }}
  labels:
    app.kubernetes.io/name: {{ item.name }}
    app.kubernetes.io/part-of: eurion
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: {{ item.name }}
  ports:
    - port: {{ item.port }}
      targetPort: {{ item.port }}
      protocol: TCP
      name: http
---
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: eurion-{{ item.name }}-hpa
  namespace: {{ k8s_namespace_prefix }}-{{ item.name | regex_replace('-service$', '') }}
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: eurion-{{ item.name }}
  minReplicas: 2
  maxReplicas: {{ 20 if item.name == 'gateway' else 10 }}
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 70
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: 80
---
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: eurion-{{ item.name }}-pdb
  namespace: {{ k8s_namespace_prefix }}-{{ item.name | regex_replace('-service$', '') }}
spec:
  minAvailable: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ item.name }}
