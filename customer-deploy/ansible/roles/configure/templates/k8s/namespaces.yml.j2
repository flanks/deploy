# Eurion Kubernetes Namespaces
# Generated by Eurion Customer Deployment for {{ org_name }}
---
{% for svc in services %}
{% if svc.required | string | lower in ['true', 'yes'] %}
apiVersion: v1
kind: Namespace
metadata:
  name: {{ k8s_namespace_prefix }}-{{ svc.name | regex_replace('-service$', '') }}
  labels:
    app.kubernetes.io/part-of: eurion
    app.kubernetes.io/managed-by: eurion-deploy
    eurion.eu/org: "{{ org_name | lower | replace(' ', '-') }}"
---
{% endif %}
{% endfor %}
apiVersion: v1
kind: Namespace
metadata:
  name: {{ k8s_namespace_prefix }}-infra
  labels:
    app.kubernetes.io/part-of: eurion
---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ k8s_namespace_prefix }}-monitoring
  labels:
    app.kubernetes.io/part-of: eurion
